{
  "expo": {
    "name": "Go News",
    "slug": "golangnews",
    "version": "2.2.1",
    "sdkVersion": "54.0.0",
    "description": "A modern news aggregator for the Go programming language",
    "icon": "./assets/images/gonews_clean.png",
    "platforms": [
      "android",
      "ios",
      "web"
    ],
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.minaandrawos.golangnews",
      "permissions": [],
      "versionCode": 9,
      "userInterfaceStyle": "automatic",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/gonews.png",
        "backgroundColor": "#021B2A"
      }
    },
    "ios": {
      "supportsTablet": true,
      "userInterfaceStyle": "automatic",
      "bundleIdentifier": "com.minaandrawos.golangnews",
      "buildNumber": "9",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "extra": {
      "eas": {
        "projectId": "393d2340-f92e-11e8-b598-4ddb31004a91"
      }
    },
    "plugins": [
      "expo-font"
    ]
  }
}
